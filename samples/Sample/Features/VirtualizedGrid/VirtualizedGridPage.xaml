<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Name="page"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.VirtualizedGrid"
             x:Class="Sample.Features.VirtualizedGrid.VirtualizedGridPage"
             x:DataType="local:VirtualizedGridViewModel"
             Title="Virtualized Grid"
             AutomationId="VirtualizedGridPage">

    <Grid RowDefinitions="Auto,*">

        <!-- Controls -->
        <VerticalStackLayout Padding="20,16,20,8" Spacing="8">
            <Label Text="Virtualized Grid"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="13"
                   TextColor="Gray" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="Columns:" VerticalTextAlignment="Center" />
                <Button Text="-" Command="{Binding DecrementColumnsCommand}" WidthRequest="40" />
                <Label Text="{Binding ColumnCount}" VerticalTextAlignment="Center" FontAttributes="Bold" />
                <Button Text="+" Command="{Binding IncrementColumnsCommand}" WidthRequest="40" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="8">
                <Button Text="Flat (240)" Command="{Binding ShowFlatCommand}" />
                <Button Text="Grouped" Command="{Binding ShowGroupedCommand}" />
                <Button Text="Load More" Command="{Binding ShowLoadMoreCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Grid swap area — only the active VirtualizedGrid is visible. -->
        <!-- VirtualizedGrid handles its own scrolling, so do NOT wrap in a ScrollView. -->
        <Grid Grid.Row="1" Margin="12,4,12,0">

            <!-- Flat grid -->
            <shiny:VirtualizedGrid ItemsSource="{Binding FlatItems}"
                                   ColumnCount="{Binding ColumnCount}"
                                   ItemSpacing="8"
                                   CellPadding="4"
                                   ItemSelectedCommand="{Binding ItemSelectedCommand}"
                                   IsVisible="{Binding IsFlatVisible}">
                <shiny:VirtualizedGrid.ItemTemplate>
                    <DataTemplate x:DataType="local:GridItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding Color}"
                                Padding="12"
                                HeightRequest="96">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="{Binding Icon}" FontSize="22"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Name}" FontAttributes="Bold"
                                       FontSize="12"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </shiny:VirtualizedGrid.ItemTemplate>
                <shiny:VirtualizedGrid.EmptyViewTemplate>
                    <DataTemplate>
                        <Label Text="No items."
                               HorizontalTextAlignment="Center"
                               Padding="32"
                               TextColor="Gray" />
                    </DataTemplate>
                </shiny:VirtualizedGrid.EmptyViewTemplate>
            </shiny:VirtualizedGrid>

            <!-- Grouped grid -->
            <shiny:VirtualizedGrid ItemsSource="{Binding GroupedSource}"
                                   ColumnCount="{Binding ColumnCount}"
                                   ItemSpacing="8"
                                   CellPadding="4"
                                   IsGroupingEnabled="True"
                                   HasStickyHeaders="True"
                                   ItemSelectedCommand="{Binding ItemSelectedCommand}"
                                   IsVisible="{Binding IsGroupedVisible}">
                <shiny:VirtualizedGrid.GroupHeaderTemplate>
                    <DataTemplate>
                        <Border StrokeThickness="0"
                                BackgroundColor="#2D3748"
                                Padding="12,8"
                                Margin="0,4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Label Text="{Binding .}"
                                   FontAttributes="Bold"
                                   FontSize="14"
                                   TextColor="White" />
                        </Border>
                    </DataTemplate>
                </shiny:VirtualizedGrid.GroupHeaderTemplate>
                <shiny:VirtualizedGrid.ItemTemplate>
                    <DataTemplate x:DataType="local:GridItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding Color}"
                                Padding="10"
                                HeightRequest="96">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="{Binding Icon}" FontSize="20"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Name}" FontSize="12"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </shiny:VirtualizedGrid.ItemTemplate>
            </shiny:VirtualizedGrid>

            <!-- Load More grid -->
            <shiny:VirtualizedGrid ItemsSource="{Binding LoadMoreItems}"
                                   ColumnCount="{Binding ColumnCount}"
                                   ItemSpacing="8"
                                   CellPadding="4"
                                   LoadMoreCommand="{Binding LoadMoreCommand}"
                                   LoadMoreThreshold="8"
                                   IsVisible="{Binding IsLoadMoreVisible}">
                <shiny:VirtualizedGrid.ItemTemplate>
                    <DataTemplate x:DataType="local:GridItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding Color}"
                                Padding="10"
                                HeightRequest="96">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <VerticalStackLayout HorizontalOptions="Center"
                                                 VerticalOptions="Center"
                                                 Spacing="4">
                                <Label Text="{Binding Icon}" FontSize="20"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Name}" FontSize="12"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </shiny:VirtualizedGrid.ItemTemplate>
            </shiny:VirtualizedGrid>

        </Grid>

    </Grid>
</ContentPage>
