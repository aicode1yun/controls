<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.VirtualizedGrid"
             x:Class="Sample.Features.VirtualizedGrid.VirtualizedGridPage"
             x:DataType="local:VirtualizedGridViewModel"
             Title="Virtualized Grid"
             AutomationId="VirtualizedGridPage">

    <Grid RowDefinitions="Auto,*">

        <!-- Controls -->
        <VerticalStackLayout Padding="20,20,20,0" Spacing="12">
            <Label Text="Virtualized Grid"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="14"
                   TextColor="Gray" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="Columns:" VerticalTextAlignment="Center" />
                <Button Text="-" Command="{Binding DecrementColumnsCommand}" WidthRequest="40" />
                <Label Text="{Binding ColumnCount}" VerticalTextAlignment="Center" FontAttributes="Bold" />
                <Button Text="+" Command="{Binding IncrementColumnsCommand}" WidthRequest="40" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="12">
                <Button Text="Flat" Command="{Binding ShowFlatCommand}" />
                <Button Text="Grouped" Command="{Binding ShowGroupedCommand}" />
                <Button Text="Load More" Command="{Binding ShowLoadMoreCommand}" />
            </HorizontalStackLayout>

            <BoxView HeightRequest="1" Color="LightGray" />
        </VerticalStackLayout>

        <!-- Grid content -->
        <ScrollView Grid.Row="1" Padding="20,12,20,20">
            <VerticalStackLayout Spacing="20">

                <!-- Flat grid -->
                <shiny:VirtualizedGrid ItemsSource="{Binding FlatItems}"
                                       ColumnCount="{Binding ColumnCount}"
                                       ItemSpacing="8"
                                       CellPadding="4"
                                       ItemSelectedCommand="{Binding ItemSelectedCommand}"
                                       IsVisible="{Binding IsFlatVisible}">
                    <shiny:VirtualizedGrid.ItemTemplate>
                        <DataTemplate x:DataType="local:GridItem">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{Binding Color}"
                                    Padding="16">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Icon}" FontSize="24" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Name}" FontAttributes="Bold" TextColor="White" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </shiny:VirtualizedGrid.ItemTemplate>
                    <shiny:VirtualizedGrid.EmptyViewTemplate>
                        <DataTemplate>
                            <Label Text="No items." HorizontalTextAlignment="Center" Padding="32" TextColor="Gray" />
                        </DataTemplate>
                    </shiny:VirtualizedGrid.EmptyViewTemplate>
                </shiny:VirtualizedGrid>

                <!-- Grouped grid -->
                <shiny:VirtualizedGrid ItemsSource="{Binding GroupedSource}"
                                       ColumnCount="{Binding ColumnCount}"
                                       ItemSpacing="8"
                                       CellPadding="4"
                                       IsGroupingEnabled="True"
                                       HasStickyHeaders="True"
                                       ItemSelectedCommand="{Binding ItemSelectedCommand}"
                                       IsVisible="{Binding IsGroupedVisible}">
                    <shiny:VirtualizedGrid.GroupHeaderTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0"
                                    BackgroundColor="#2D3748"
                                    Padding="8,6">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="6" />
                                </Border.StrokeShape>
                                <Label Text="{Binding .}"
                                       FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>
                        </DataTemplate>
                    </shiny:VirtualizedGrid.GroupHeaderTemplate>
                    <shiny:VirtualizedGrid.ItemTemplate>
                        <DataTemplate x:DataType="local:GridItem">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{Binding Color}"
                                    Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Icon}" FontSize="20" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Name}" FontSize="13" TextColor="White" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </shiny:VirtualizedGrid.ItemTemplate>
                </shiny:VirtualizedGrid>

                <!-- Load More grid -->
                <shiny:VirtualizedGrid ItemsSource="{Binding LoadMoreItems}"
                                       ColumnCount="{Binding ColumnCount}"
                                       ItemSpacing="8"
                                       CellPadding="4"
                                       ShowLoadMoreButton="{Binding CanLoadMore}"
                                       LoadMoreCommand="{Binding LoadMoreCommand}"
                                       IsVisible="{Binding IsLoadMoreVisible}">
                    <shiny:VirtualizedGrid.HeaderTemplate>
                        <DataTemplate>
                            <Border StrokeThickness="0"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#667EEA" Offset="0.0" />
                                        <GradientStop Color="#764BA2" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="Featured Collection"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </Border>
                        </DataTemplate>
                    </shiny:VirtualizedGrid.HeaderTemplate>
                    <shiny:VirtualizedGrid.ItemTemplate>
                        <DataTemplate x:DataType="local:GridItem">
                            <Border StrokeThickness="0"
                                    BackgroundColor="{Binding Color}"
                                    Padding="12">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <VerticalStackLayout HorizontalOptions="Center" Spacing="4">
                                    <Label Text="{Binding Icon}" FontSize="20" HorizontalTextAlignment="Center" />
                                    <Label Text="{Binding Name}" FontSize="13" TextColor="White" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </shiny:VirtualizedGrid.ItemTemplate>
                    <shiny:VirtualizedGrid.FooterTemplate>
                        <DataTemplate>
                            <Label Text="{Binding LoadMoreItems.Count, StringFormat='Showing {0} items'}"
                                   HorizontalTextAlignment="Center"
                                   FontSize="12"
                                   TextColor="Gray"
                                   Margin="0,8,0,0" />
                        </DataTemplate>
                    </shiny:VirtualizedGrid.FooterTemplate>
                </shiny:VirtualizedGrid>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>
