<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.StaggeredGrid"
             x:Class="Sample.Features.StaggeredGrid.StaggeredGridPage"
             x:DataType="local:StaggeredGridViewModel"
             Title="Staggered Grid"
             AutomationId="StaggeredGridPage">

    <Grid RowDefinitions="Auto,*">

        <!-- Controls -->
        <VerticalStackLayout Padding="20,16,20,8" Spacing="8">
            <Label Text="Pinterest-style Grid"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="13"
                   TextColor="Gray" />

            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                <Label Text="Columns:" VerticalTextAlignment="Center" />
                <Button Text="-" Command="{Binding DecrementColumnsCommand}" WidthRequest="40" />
                <Label Text="{Binding ColumnCount}" VerticalTextAlignment="Center" FontAttributes="Bold" />
                <Button Text="+" Command="{Binding IncrementColumnsCommand}" WidthRequest="40" />
                <Button Text="Shuffle" Command="{Binding ShuffleCommand}" />
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Pinterest grid — the control handles its own scrolling, do NOT wrap in ScrollView -->
        <shiny:StaggeredGrid Grid.Row="1"
                             Margin="12,0,12,0"
                             ItemsSource="{Binding Items}"
                             ColumnCount="{Binding ColumnCount}"
                             ColumnSpacing="8"
                             RowSpacing="8"
                             ItemSelectedCommand="{Binding ItemSelectedCommand}">
            <shiny:StaggeredGrid.ItemTemplate>
                <DataTemplate x:DataType="local:StaggeredItem">
                    <Border StrokeThickness="0"
                            BackgroundColor="{Binding Accent}"
                            HeightRequest="{Binding Height}">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="14" />
                        </Border.StrokeShape>
                        <Grid>
                            <Image Source="{Binding ImageUrl}"
                                   Aspect="AspectFill" />

                            <!-- Bottom gradient for legible captions -->
                            <BoxView VerticalOptions="End"
                                     HeightRequest="80">
                                <BoxView.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0.0" />
                                        <GradientStop Color="#A0000000" Offset="1.0" />
                                    </LinearGradientBrush>
                                </BoxView.Background>
                            </BoxView>

                            <VerticalStackLayout VerticalOptions="End"
                                                 Padding="12,8"
                                                 Spacing="0">
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="14"
                                       TextColor="White"
                                       LineBreakMode="TailTruncation" />
                                <Label Text="{Binding Category}"
                                       FontSize="11"
                                       TextColor="White"
                                       Opacity="0.85" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </shiny:StaggeredGrid.ItemTemplate>
            <shiny:StaggeredGrid.EmptyViewTemplate>
                <DataTemplate>
                    <Label Text="No pins to display."
                           HorizontalTextAlignment="Center"
                           Padding="32"
                           TextColor="Gray" />
                </DataTemplate>
            </shiny:StaggeredGrid.EmptyViewTemplate>
        </shiny:StaggeredGrid>

    </Grid>
</ContentPage>
