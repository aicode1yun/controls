<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:shiny="http://shiny.net/maui/controls"
             xmlns:local="clr-namespace:Sample.Features.CarouselGallery"
             x:Class="Sample.Features.CarouselGallery.CarouselGalleryPage"
             x:DataType="local:CarouselGalleryViewModel"
             Title="Carousel Gallery"
             AutomationId="CarouselGalleryPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label Text="Carousel Gallery"
                   FontSize="24"
                   FontAttributes="Bold" />

            <Label Text="{Binding StatusMessage}"
                   FontSize="14"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Basic Carousel — 20 genres -->
            <Label Text="Basic Carousel" FontAttributes="Bold" FontSize="18" />
            <Label Text="{Binding BasicItems.Count, StringFormat='{0} items — peek/snap, swipe to browse'}"
                   FontSize="12"
                   TextColor="Gray" />

            <shiny:CarouselGallery ItemsSource="{Binding BasicItems}"
                                   ItemWidth="280"
                                   ItemHeight="160"
                                   ItemSpacing="16"
                                   PeekAreaInsets="40"
                                   CurrentPosition="{Binding CurrentPosition}"
                                   HeightRequest="180">
                <shiny:CarouselGallery.ItemTemplate>
                    <DataTemplate x:DataType="local:CarouselItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding Color}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="8">
                                <Label Text="{Binding Icon}"
                                       FontSize="32"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Title}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </shiny:CarouselGallery.ItemTemplate>
            </shiny:CarouselGallery>

            <Label Text="{Binding CurrentPosition, StringFormat='Position: {0}'}"
                   HorizontalTextAlignment="Center"
                   FontSize="14"
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Scale Effect Carousel — same data, focus scale -->
            <Label Text="With Scale Effect" FontAttributes="Bold" FontSize="18" />

            <shiny:CarouselGallery ItemsSource="{Binding BasicItems}"
                                   ItemWidth="240"
                                   ItemHeight="140"
                                   ItemSpacing="12"
                                   PeekAreaInsets="60"
                                   FocusedItemScale="1.0"
                                   UnfocusedItemScale="0.85"
                                   HeightRequest="160">
                <shiny:CarouselGallery.ItemTemplate>
                    <DataTemplate x:DataType="local:CarouselItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding Color}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="4">
                                <Label Text="{Binding Icon}"
                                       FontSize="28"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Title}"
                                       FontSize="14"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </shiny:CarouselGallery.ItemTemplate>
            </shiny:CarouselGallery>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Destination Carousel — 16 items with selection -->
            <Label Text="Destinations" FontAttributes="Bold" FontSize="18" />
            <Label Text="{Binding GradientItems.Count, StringFormat='{0} items — tap a card to select'}"
                   FontSize="12"
                   TextColor="Gray" />

            <shiny:CarouselGallery ItemsSource="{Binding GradientItems}"
                                   ItemWidth="300"
                                   ItemHeight="200"
                                   ItemSpacing="20"
                                   PeekAreaInsets="30"
                                   ItemSelectedCommand="{Binding ItemSelectedCommand}"
                                   HeightRequest="220">
                <shiny:CarouselGallery.ItemTemplate>
                    <DataTemplate x:DataType="local:CarouselItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding Color}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#000000" Offset="0,4" Radius="12" Opacity="0.15" />
                            </Border.Shadow>
                            <VerticalStackLayout VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="6">
                                <Label Text="{Binding Icon}"
                                       FontSize="40"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="{Binding Subtitle}"
                                       FontSize="12"
                                       TextColor="White"
                                       Opacity="0.85"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </shiny:CarouselGallery.ItemTemplate>
            </shiny:CarouselGallery>

            <BoxView HeightRequest="1" Color="LightGray" />

            <!-- Photo Carousel — 24 photos -->
            <Label Text="Photo Gallery" FontAttributes="Bold" FontSize="18" />
            <Label Text="{Binding PhotoItems.Count, StringFormat='{0} photos — full-bleed image cards'}"
                   FontSize="12"
                   TextColor="Gray" />

            <shiny:CarouselGallery ItemsSource="{Binding PhotoItems}"
                                   ItemWidth="320"
                                   ItemHeight="220"
                                   ItemSpacing="14"
                                   PeekAreaInsets="40"
                                   ItemSelectedCommand="{Binding ItemSelectedCommand}"
                                   HeightRequest="240">
                <shiny:CarouselGallery.ItemTemplate>
                    <DataTemplate x:DataType="local:CarouselPhotoItem">
                        <Border StrokeThickness="0"
                                BackgroundColor="{Binding Color}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Grid>
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />

                                <BoxView VerticalOptions="End"
                                         HeightRequest="80">
                                    <BoxView.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0.0" />
                                            <GradientStop Color="#B0000000" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>

                                <Label Text="{Binding Title}"
                                       VerticalOptions="End"
                                       Padding="14,10"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       TextColor="White" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </shiny:CarouselGallery.ItemTemplate>
            </shiny:CarouselGallery>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
