<?xml version="1.0" encoding="utf-8" ?>
<shiny:ShinyContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shiny="http://shiny.net/maui/controls"
    xmlns:local="clr-namespace:Sample.Features.KitchenSink"
    x:Class="Sample.Features.KitchenSink.KitchenSinkPage"
    x:DataType="local:KitchenSinkViewModel"
    Title="Kitchen Sink">

  <shiny:ShinyContentPage.PageContent>
    <Grid>

        <!-- Main content -->
        <VerticalStackLayout VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8">
            <Label Text="Kitchen Sink"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalTextAlignment="Center" />
            <Label Text="Tap the chat button to pick a conversation"
                   FontSize="14"
                   TextColor="Gray"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <!-- FabMenu: open chats -->
        <shiny:FabMenu Text="Chats"
                       FabBackgroundColor="#6C63FF"
                       TextColor="White"
                       HasBackdrop="True"
                       CloseOnBackdropTap="True"
                       CloseOnItemTap="True">
            <shiny:FabMenuItem Text="Alice Johnson"
                               FabBackgroundColor="#E3F2FD"
                               Command="{Binding OpenChatCommand}"
                               CommandParameter="alice" />
            <shiny:FabMenuItem Text="Bob Smith"
                               FabBackgroundColor="#FFF3E0"
                               Command="{Binding OpenChatCommand}"
                               CommandParameter="bob" />
            <shiny:FabMenuItem Text="Carol Davis"
                               FabBackgroundColor="#F3E5F5"
                               Command="{Binding OpenChatCommand}"
                               CommandParameter="carol" />
        </shiny:FabMenu>

    </Grid>
  </shiny:ShinyContentPage.PageContent>

  <shiny:ShinyContentPage.Panels>
    <!-- Sheet: chat window -->
    <shiny:FloatingPanel IsOpen="{Binding IsChatOpen}"
                         HasBackdrop="True"
                         CloseOnBackdropTap="True"
                         HandleColor="Gray"
                         PanelBackgroundColor="White"
                         PanelCornerRadius="20"
                         FitContent="True">
        <shiny:FloatingPanel.HeaderTemplate>
            <Border BackgroundColor="#6C63FF"
                    Padding="16,12"
                    StrokeThickness="0">
                <Label Text="{Binding ChatTitle}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White" />
            </Border>
        </shiny:FloatingPanel.HeaderTemplate>

        <shiny:ChatView Messages="{Binding Messages}"
                        Participants="{Binding Participants}"
                        TypingParticipants="{Binding TypingParticipants}"
                        IsMultiPerson="False"
                        ShowAvatarsInSingleChat="True"
                        SendCommand="{Binding SendCommand}"
                        MessageTappedCommand="{Binding MessageTappedCommand}"
                        ToolsIcon="dotnet_bot.png"
                        MyBubbleColor="#DCF8C6"
                        OtherBubbleColor="White"
                        PlaceholderText="Type a message..."
                        HeightRequest="500">
            <shiny:ChatView.MessageTemplateSelector>
                <local:KitchenSinkMessageTemplateSelector>
                    <local:KitchenSinkMessageTemplateSelector.TextTemplate>
                        <DataTemplate x:DataType="shiny:ChatMessage">
                            <Label Text="{Binding Text}" />
                        </DataTemplate>
                    </local:KitchenSinkMessageTemplateSelector.TextTemplate>
                    <local:KitchenSinkMessageTemplateSelector.ImageTemplate>
                        <DataTemplate x:DataType="shiny:ChatMessage">
                            <shiny:ImageViewer Source="{Binding ImageUrl}"
                                               HeightRequest="200"
                                               WidthRequest="280"
                                               Aspect="AspectFill" />
                        </DataTemplate>
                    </local:KitchenSinkMessageTemplateSelector.ImageTemplate>
                </local:KitchenSinkMessageTemplateSelector>
            </shiny:ChatView.MessageTemplateSelector>
            <shiny:ChatView.ToolItems>
                <shiny:ChatEntryTool Text="Take Photo"
                                     Icon="dotnet_bot.png"
                                     FabBackgroundColor="#4CAF50"
                                     Command="{Binding TakePhotoCommand}" />
                <shiny:ChatEntryTool Text="Pick Image"
                                     Icon="dotnet_bot.png"
                                     FabBackgroundColor="#FF9800"
                                     Command="{Binding PickImageCommand}" />
            </shiny:ChatView.ToolItems>
        </shiny:ChatView>
    </shiny:FloatingPanel>
  </shiny:ShinyContentPage.Panels>

</shiny:ShinyContentPage>
