<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:shiny="http://shiny.net/maui/controls"
    xmlns:local="clr-namespace:Sample.Features.Chat"
    x:Class="Sample.Features.Chat.ChatPage"
    x:DataType="local:ChatViewModel"
    Title="Chat">

    <Grid RowDefinitions="Auto,Auto,*">

        <HorizontalStackLayout Grid.Row="0" Spacing="8" Padding="12,8">
            <Button Text="Simulate Incoming"
                    Command="{Binding SimulateIncomingCommand}"
                    FontSize="12"
                    HeightRequest="36" />
            <Button Text="Toggle Typing"
                    Command="{Binding ToggleTypingCommand}"
                    FontSize="12"
                    HeightRequest="36" />
            <Switch IsToggled="{Binding IsMultiPerson}"
                    VerticalOptions="Center" />
            <Label Text="Multi-Person"
                   VerticalOptions="Center"
                   FontSize="12" />
            <Switch IsToggled="{Binding IsChatSpeakingEnabled}"
                    VerticalOptions="Center" />
            <Label Text="TTS"
                   VerticalOptions="Center"
                   FontSize="12" />
        </HorizontalStackLayout>

        <Label Grid.Row="1"
               Text="TTS is powered by a custom IFeedbackService using Shiny.Speech (ITextToSpeechService). Incoming messages are spoken aloud when enabled."
               FontSize="11"
               TextColor="Gray"
               Padding="12,0,12,4"
               LineBreakMode="WordWrap" />

        <shiny:ChatView Grid.Row="2"
                        Messages="{Binding Messages}"
                        Participants="{Binding Participants}"
                        IsMultiPerson="{Binding IsMultiPerson}"
                        TypingParticipants="{Binding TypingParticipants}"
                        SendCommand="{Binding SendCommand}"
                        LoadMoreCommand="{Binding LoadMoreCommand}"
                        ToolsIcon="dotnet_bot.png"
                        MyBubbleColor="#DCF8C6"
                        OtherBubbleColor="White"
                        PlaceholderText="Type a message...">
            <shiny:ChatView.ToolItems>
                <shiny:FabMenuItem Text="Take Photo"
                                   Icon="dotnet_bot.png"
                                   FabBackgroundColor="#4CAF50"
                                   Command="{Binding TakePhotoCommand}" />
                <shiny:FabMenuItem Text="Pick Image"
                                   Icon="dotnet_bot.png"
                                   FabBackgroundColor="#FF9800"
                                   Command="{Binding PickImageCommand}" />
            </shiny:ChatView.ToolItems>
        </shiny:ChatView>
    </Grid>

</ContentPage>
