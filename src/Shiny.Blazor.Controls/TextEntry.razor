@namespace Shiny.Blazor.Controls

<div class="shiny-te @(IsFocused ? "shiny-te--focused" : "") @(HasError ? "shiny-te--error" : "") @CssClass"
     style="@RootStyle"
     @attributes="AdditionalAttributes">

    <div class="shiny-te-border"
         style="@BorderStyle"
         @onclick="FocusInput">

        @if (LeftTools is { Count: > 0 })
        {
            <div class="shiny-te-tools shiny-te-tools--left" style="--shiny-te-border-color: @CurrentBorderColor;">
                @foreach (var tool in LeftTools)
                {
                    if (tool.IsVisible)
                    {
                        <button class="shiny-te-tool-btn @tool.CssClass"
                                type="button"
                                style="color: @tool.ToolColor;"
                                @onclick="() => OnToolClicked(tool)"
                                @onclick:stopPropagation>
                            @if (!string.IsNullOrEmpty(tool.Icon))
                            {
                                <span class="shiny-te-tool-icon">@tool.Icon</span>
                            }
                            @if (!string.IsNullOrEmpty(tool.Text))
                            {
                                <span class="shiny-te-tool-text">@tool.Text</span>
                            }
                        </button>
                    }
                }
            </div>
        }

        <div class="shiny-te-field">
            <label class="shiny-te-placeholder @(IsPlaceholderUp ? "shiny-te-placeholder--up" : "")"
                   style="@PlaceholderStyle">
                @Placeholder
            </label>
            <input @ref="inputRef"
                   class="shiny-te-input"
                   type="@InputType"
                   inputmode="@InputMode"
                   value="@DisplayText"
                   readonly="@IsReadOnly"
                   maxlength="@InputMaxLength"
                   @oninput="OnInput"
                   @onfocus="OnFocusIn"
                   @onblur="OnFocusOut"
                   @onkeydown="OnKeyDown"
                   style="@InputStyle" />
        </div>

        @if (RightTools is { Count: > 0 })
        {
            <div class="shiny-te-tools shiny-te-tools--right" style="--shiny-te-border-color: @CurrentBorderColor;">
                @foreach (var tool in RightTools)
                {
                    if (tool.IsVisible)
                    {
                        <button class="shiny-te-tool-btn @tool.CssClass"
                                type="button"
                                style="color: @tool.ToolColor;"
                                @onclick="() => OnToolClicked(tool)"
                                @onclick:stopPropagation>
                            @if (!string.IsNullOrEmpty(tool.Icon))
                            {
                                <span class="shiny-te-tool-icon">@tool.Icon</span>
                            }
                            @if (!string.IsNullOrEmpty(tool.Text))
                            {
                                <span class="shiny-te-tool-text">@tool.Text</span>
                            }
                        </button>
                    }
                }
            </div>
        }
    </div>

    @if (!string.IsNullOrEmpty(HintDisplay))
    {
        <div class="shiny-te-hint" style="@HintStyle">
            @HintDisplay
        </div>
    }
</div>
